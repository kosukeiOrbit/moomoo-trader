# moomoo OpenAPI
MOOMOO_HOST=127.0.0.1
MOOMOO_PORT=11111
MOOMOO_TRADE_PWD=your_password

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# 取引設定
TRADE_ENV=SIMULATE          # SIMULATE or REAL
MAX_DAILY_LOSS_PCT=0.03     # 日次最大損失 3%
MAX_DRAWDOWN_PCT=0.10       # 最大ドローダウン 10%
POSITION_MAX_PCT=0.02       # 1ポジション最大 2%

# Discord Webhook 通知（チャンネルごとに分離）
DISCORD_WEBHOOK_SIGNAL=https://discord.com/api/webhooks/xxx/yyy   # mt-signal
DISCORD_WEBHOOK_ALERT=https://discord.com/api/webhooks/xxx/yyy    # mt-alert
DISCORD_WEBHOOK_SUMMARY=https://discord.com/api/webhooks/xxx/yyy  # mt-summary

# DB
DATABASE_URL=postgresql://user:pass@localhost/daytrade
